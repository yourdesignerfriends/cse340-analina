<h1><%= title %></h1>

<%- messages() %>

<% if (errors) { %>
    <div class="errors"><%= errors %></div>
<% } %>

<div class="account-info">
    <h2>Welcome <%= accountData.account_firstname %></h2>

    <p>You're logged in</p>

    <!-- Update account link (visible for all users) -->
    <p>
        <a href="/account/update/<%= accountId %>">Edit Account Information</a>
    </p>

    <!-- Favorites link (visible for all users) -->
    <p>
        <a href="/favorites">My Favorites</a>
    </p>

    <!-- Inventory management only for Employee/Admin -->
    <% if (accountType === "Employee" || accountType === "Admin") { %>
        <p>
            <a href="/inv/">Manage Inventory</a>
        </p>
    <% } %>
    <!-- Favorite Stats (Admin only) -->
    <% if (accountType === "Admin") { %>
        <p>
            <a href="/admin/favorite-stats">Favorite Stats</a>
        </p>
    <% } %>
</div>